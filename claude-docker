#!/usr/bin/env bash
# claude-docker — Run Claude Code in an isolated Docker container
# Install: make install
# Usage:   claude-docker [command]

set -euo pipefail

IMAGE_NAME="claude-code-sandbox"
DOCKERFILE_NAME="Dockerfile.claude"
DOCKERFILE_LOCAL="$HOME/.claude-vm/$DOCKERFILE_NAME"

GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
log()     { echo -e "${BLUE}==> ${NC}$1"; }
success() { echo -e "${GREEN} ✓ ${NC}$1"; }
warn()    { echo -e "${YELLOW} ⚠ ${NC}$1"; }
die()     { echo -e "${RED} ✗ ${NC}$1"; exit 1; }

WORK_DIR="$(pwd)"
PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-*$//')"

# Detect monorepo root by walking up to find lock file
find_project_root() {
  local dir="$WORK_DIR"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/pnpm-lock.yaml" ] || [ -f "$dir/package-lock.json" ] || [ -f "$dir/yarn.lock" ] || [ -f "$dir/pnpm-workspace.yaml" ]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "$WORK_DIR"
}

PROJECT_DIR="$(find_project_root)"
PROJECT_NAME="$(basename "$PROJECT_DIR" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-*$//')"
CONTAINER_NAME="claude-docker-${PROJECT_NAME}"
VOLUME_NAME="claude-docker-nm-${PROJECT_NAME}"

USE_TMUX=false
GCLOUD_LOGIN=false

check_prereqs() {
  if ! command -v docker &>/dev/null; then
    die "Docker not found. Install Docker Desktop: https://docs.docker.com/get-docker/"
  fi
  if ! docker info &>/dev/null 2>&1; then
    die "Docker daemon is not running. Start Docker Desktop and try again."
  fi
}

find_dockerfile() {
  if [ -f "$DOCKERFILE_LOCAL" ]; then
    echo "$DOCKERFILE_LOCAL"
  elif [ -f "$(dirname "$(readlink -f "$0")")/$DOCKERFILE_NAME" ]; then
    echo "$(dirname "$(readlink -f "$0")")/$DOCKERFILE_NAME"
  else
    die "Dockerfile not found. Expected at $DOCKERFILE_LOCAL or next to this script."
  fi
}

ensure_image() {
  if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    local dockerfile
    dockerfile="$(find_dockerfile)"
    log "Building Docker image '$IMAGE_NAME' (first run, may take a few minutes)..."
    docker build -t "$IMAGE_NAME" --build-arg HOST_UID="$(id -u)" -f "$dockerfile" "$(dirname "$dockerfile")"
    success "Image '$IMAGE_NAME' built"
  fi
}

detect_pkg_manager() {
  local dir="$PROJECT_DIR"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/pnpm-lock.yaml" ]; then
      echo "pnpm install"
      return
    elif [ -f "$dir/yarn.lock" ]; then
      echo "yarn install"
      return
    elif [ -f "$dir/package-lock.json" ]; then
      echo "npm install"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "npm install"
}

build_host_flags() {
  local flags=""
  while IFS= read -r line; do
    # Skip comments and empty lines
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "$line" ]] && continue
    # Match 127.0.0.1 entries, skip localhost/broadcasthost
    if echo "$line" | grep -qE '^127\.0\.0\.1[[:space:]]'; then
      local hosts
      hosts=$(echo "$line" | awk '{$1=""; print}' | xargs)
      for h in $hosts; do
        [[ "$h" == "localhost" || "$h" == "broadcasthost" ]] && continue
        flags="$flags --add-host ${h}:host-gateway"
      done
    fi
  done < /etc/hosts 2>/dev/null
  echo "$flags"
}

cmd_run() {
  check_prereqs
  ensure_image

  # If container is already running, attach to it
  if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    log "Attaching to running container '$CONTAINER_NAME'..."
    docker exec -it "$CONTAINER_NAME" bash -c "cd '${WORK_DIR}' && claude --dangerously-skip-permissions"
    return
  fi

  # Remove stopped container with same name
  docker rm -f "$CONTAINER_NAME" &>/dev/null || true

  log "Starting container '$CONTAINER_NAME'..."
  echo -e "  ${BLUE}Local:${NC}     $WORK_DIR"
  echo -e "  ${BLUE}Root:${NC}      $PROJECT_DIR"
  echo -e "  ${BLUE}Container:${NC} $CONTAINER_NAME"
  echo ""

  # Build volume mounts
  local vol_flags=()
  vol_flags+=(-v "$PROJECT_DIR:$PROJECT_DIR")
  vol_flags+=(-v "$HOME/.claude:/home/claude/.claude")
  [ -f "$HOME/.claude.json" ] && vol_flags+=(-v "$HOME/.claude.json:/home/claude/.claude.json")

  # node_modules volume overlay (only if package.json exists)
  if [ -f "$PROJECT_DIR/package.json" ]; then
    vol_flags+=(-v "${VOLUME_NAME}:${PROJECT_DIR}/node_modules")
  fi

  # Optional config mounts
  [ -f "$HOME/.gitconfig" ] && vol_flags+=(-v "$HOME/.gitconfig:/home/claude/.gitconfig:ro")
  [ -d "$HOME/.ssh" ] && vol_flags+=(-v "$HOME/.ssh:/home/claude/.ssh:ro")
  [ -d "$HOME/.config/gcloud" ] && vol_flags+=(-v "$HOME/.config/gcloud:/home/claude/.config/gcloud")

  # Host entries
  local host_flags
  host_flags="$(build_host_flags)"

  # Build startup command
  local pkg_cmd
  pkg_cmd="$(detect_pkg_manager)"

  # Share host pnpm store with container to avoid re-downloading packages
  local pnpm_store=""
  if [[ "$pkg_cmd" == "pnpm install" ]] && command -v pnpm &>/dev/null; then
    pnpm_store="$(pnpm store path 2>/dev/null | sed 's|/v[0-9].*||')"
  fi
  if [ -n "$pnpm_store" ]; then
    vol_flags+=(-v "$pnpm_store:/home/claude/.pnpm-store")
  fi

  local startup_cmd=""
  # Install pnpm if needed
  if [[ "$pkg_cmd" == "pnpm install" ]]; then
    startup_cmd="command -v pnpm >/dev/null || sudo npm install -g pnpm; pnpm config set --global store-dir /home/claude/.pnpm-store; "
  fi
  # Install deps if node_modules volume is empty and package.json exists
  if [ -f "$PROJECT_DIR/package.json" ]; then
    startup_cmd="${startup_cmd}if [ ! -d '${PROJECT_DIR}/node_modules/node_modules' ] && [ -z \"\$(ls -A '${PROJECT_DIR}/node_modules' 2>/dev/null)\" ]; then cd '${PROJECT_DIR}' && ${pkg_cmd}; fi; "
  fi
  if [ "$GCLOUD_LOGIN" = true ]; then
    startup_cmd="${startup_cmd}echo '==> Running gcloud auth login...' && gcloud auth login --no-launch-browser && gcloud auth application-default login --no-launch-browser; "
  fi
  startup_cmd="${startup_cmd}cd '${WORK_DIR}' && claude --dangerously-skip-permissions"

  # shellcheck disable=SC2086
  docker run -it \
    --name "$CONTAINER_NAME" \
    --hostname "claude-sandbox" \
    "${vol_flags[@]}" \
    -e ANTHROPIC_API_KEY \
    $host_flags \
    "$IMAGE_NAME" \
    -c "$startup_cmd"
}

cmd_stop() {
  check_prereqs
  if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    log "Stopping container '$CONTAINER_NAME'..."
    docker stop "$CONTAINER_NAME" --time 30
    success "Container stopped"
  else
    warn "Container '$CONTAINER_NAME' is not running"
  fi
}

cmd_status() {
  check_prereqs
  if docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    docker inspect "$CONTAINER_NAME" --format '
  Name:    {{.Name}}
  Status:  {{.State.Status}}
  Started: {{.State.StartedAt}}
  Image:   {{.Config.Image}}'
    echo ""
    echo "  Mounts:"
    docker inspect "$CONTAINER_NAME" --format '{{range .Mounts}}    {{.Type}}: {{.Source}} → {{.Destination}}
{{end}}'
  else
    warn "No container found for project '$PROJECT_NAME'"
  fi
}

cmd_update() {
  check_prereqs
  local dockerfile
  dockerfile="$(find_dockerfile)"
  log "Rebuilding image '$IMAGE_NAME' (no cache)..."
  docker build --no-cache -t "$IMAGE_NAME" --build-arg HOST_UID="$(id -u)" -f "$dockerfile" "$(dirname "$dockerfile")"
  success "Image '$IMAGE_NAME' updated"
}

cmd_clean() {
  check_prereqs
  log "Removing container '$CONTAINER_NAME'..."
  docker rm -f "$CONTAINER_NAME" 2>/dev/null && success "Container removed" || warn "Container not found"
  log "Removing volume '$VOLUME_NAME'..."
  docker volume rm "$VOLUME_NAME" 2>/dev/null && success "Volume removed" || warn "Volume not found"
}

cmd_shell() {
  check_prereqs
  if ! docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    die "Container '$CONTAINER_NAME' is not running. Start it with: claude-docker"
  fi
  docker exec -it "$CONTAINER_NAME" bash -c "cd '${WORK_DIR}' && exec bash"
}

cmd_list() {
  check_prereqs
  echo -e "${BLUE}Running claude-docker containers:${NC}"
  docker ps --filter "name=claude-docker-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
}

usage() {
  echo ""
  echo -e "  ${BLUE}claude-docker${NC} — Run Claude Code in an isolated Docker container"
  echo ""
  echo -e "  ${GREEN}From any project directory:${NC}"
  echo "    claude-docker              Launch Claude Code in this repo"
  echo "    claude-docker shell        Open a bash shell in the container"
  echo "    claude-docker status       Container info and mounts"
  echo "    claude-docker list         List all running claude-docker containers"
  echo ""
  echo -e "  ${GREEN}Management:${NC}"
  echo "    claude-docker stop         Stop the container"
  echo "    claude-docker clean        Remove container and node_modules volume"
  echo "    claude-docker update       Rebuild the Docker image (no cache)"
  echo ""
  echo -e "  ${GREEN}Flags:${NC}"
  echo "    --gcloud-login          Run gcloud auth login before starting Claude"
  echo ""
}

# Parse flags
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --tmux) USE_TMUX=true; shift ;;
    --gcloud-login) GCLOUD_LOGIN=true; shift ;;
    *) die "Unknown flag '$1'. Run: claude-docker help" ;;
  esac
done

case "${1:-run}" in
  run|"")    cmd_run ;;
  stop)      cmd_stop ;;
  status)    cmd_status ;;
  update)    cmd_update ;;
  clean)     cmd_clean ;;
  shell)     cmd_shell ;;
  list)      cmd_list ;;
  help|--help|-h) usage ;;
  *) die "Unknown command '$1'. Run: claude-docker help" ;;
esac
