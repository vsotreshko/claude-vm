#!/usr/bin/env bash
# claude-run — Run Claude Code in an isolated VM mounted to the current repo
# Install: make install
# Usage:   claude-run [command]

set -euo pipefail

USE_TMUX=false
VM_NAME="claude-sandbox"
VM_CPUS="2"
VM_MEMORY="4G"
VM_DISK="30G"
UBUNTU_VERSION="22.04"
BOOTSTRAP_LOCAL="$HOME/.claude-vm/vm-bootstrap.sh"
BOOTSTRAP_URL="https://raw.githubusercontent.com/vsotreshko/claude-vm/main/vm-bootstrap.sh"
TTYD_PORT="7681"

GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
log()     { echo -e "${BLUE}==> ${NC}$1"; }
success() { echo -e "${GREEN} ✓ ${NC}$1"; }
warn()    { echo -e "${YELLOW} ⚠ ${NC}$1"; }
die()     { echo -e "${RED} ✗ ${NC}$1"; exit 1; }

WORK_DIR="$(pwd)"
PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-*$//')"

# Detect monorepo root by walking up to find lock file
find_project_root() {
  local dir="$WORK_DIR"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/pnpm-lock.yaml" ] || [ -f "$dir/package-lock.json" ] || [ -f "$dir/yarn.lock" ] || [ -f "$dir/pnpm-workspace.yaml" ]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "$WORK_DIR"
}

PROJECT_DIR="$(find_project_root)"
VM_MOUNT_POINT="${PROJECT_DIR}"
TMUX_SESSION="claude-${PROJECT_NAME}"

LOCK_FILE="/tmp/claude-vm.lock"

acquire_lock() {
  while ! ( set -o noclobber; echo $$ > "$LOCK_FILE" ) 2>/dev/null; do
    # Check if the holding process is still alive
    local holder
    holder=$(cat "$LOCK_FILE" 2>/dev/null)
    if [ -n "$holder" ] && ! kill -0 "$holder" 2>/dev/null; then
      rm -f "$LOCK_FILE"
      continue
    fi
    sleep 1
  done
  trap 'rm -f "$LOCK_FILE"' EXIT
}

release_lock() {
  rm -f "$LOCK_FILE"
}

check_prereqs() {
  if ! command -v brew &>/dev/null; then
    die "Homebrew not found. Install it first: https://brew.sh"
  fi
  if ! command -v multipass &>/dev/null; then
    log "Multipass not found — installing..."
    brew install multipass
    success "Multipass installed"
  fi
}

ensure_vm() {
  if ! multipass info "$VM_NAME" &>/dev/null 2>&1; then
    log "Creating VM '$VM_NAME'..."
    multipass launch --name "$VM_NAME" \
      --cpus "$VM_CPUS" --memory "$VM_MEMORY" --disk "$VM_DISK" "$UBUNTU_VERSION"
    success "VM created"
  fi
  local state
  state=$(multipass info "$VM_NAME" | grep State | awk '{print $2}')
  if [ "$state" != "Running" ]; then
    log "Starting VM..."
    multipass start "$VM_NAME"
    sleep 2
  fi

  # Wait for SSH to be ready
  log "Waiting for VM SSH..."
  local retries=0
  while ! multipass exec "$VM_NAME" -- true 2>/dev/null; do
    retries=$((retries + 1))
    [ "$retries" -gt 30 ] && die "VM SSH not ready after 30 attempts"
    sleep 2
  done
  success "VM SSH ready"
}

ensure_bootstrapped() {
  if ! multipass exec "$VM_NAME" -- test -f /home/ubuntu/.claude-vm-ready 2>/dev/null; then
    log "Bootstrapping VM (~3 min)..."
    local script
    if [ -f "$BOOTSTRAP_LOCAL" ]; then
      script="$BOOTSTRAP_LOCAL"
    else
      script=$(mktemp /tmp/vm-bootstrap-XXXXXX.sh)
      trap 'rm -f "$script"' EXIT
      curl -fsSL "$BOOTSTRAP_URL" -o "$script" \
        || die "Bootstrap not found. Put vm-bootstrap.sh at $BOOTSTRAP_LOCAL"
    fi
    multipass transfer "$script" "$VM_NAME":/home/ubuntu/vm-bootstrap.sh
    multipass exec "$VM_NAME" -- chmod +x /home/ubuntu/vm-bootstrap.sh
    multipass exec "$VM_NAME" -- bash /home/ubuntu/vm-bootstrap.sh
    warn "Now authenticate Tailscale:"
    warn "  multipass shell $VM_NAME"
    warn "  sudo tailscale up"
  fi
}

ensure_host_docker_internal() {
  multipass exec "$VM_NAME" -- sudo /usr/local/bin/update-host-docker-internal.sh 2>/dev/null || true
}

sync_hosts() {
  # Copy Mac /etc/hosts entries to VM, rewriting 127.0.0.1 to Mac's real IP
  # so that .local domains resolve to the Mac (via SSH tunnel) not the VM itself
  multipass transfer /etc/hosts "$VM_NAME":/tmp/mac-hosts 2>/dev/null || return 0
  multipass exec "$VM_NAME" -- bash -c "
    # Remove old synced entries
    sudo sed -i '/# claude-vm-sync/d' /etc/hosts
    # Re-add with 127.0.0.1 preserved (SSH tunnel makes localhost reach Mac)
    grep -E '^127\.0\.0\.1\s' /tmp/mac-hosts | grep -vE '(localhost|broadcasthost)' | while IFS= read -r line; do
      hostnames=\$(echo \"\$line\" | awk '{\$1=\"\"; print}' | xargs)
      [ -z \"\$hostnames\" ] && continue
      echo \"127.0.0.1 \$hostnames # claude-vm-sync\" | sudo tee -a /etc/hosts > /dev/null
    done
    rm -f /tmp/mac-hosts
  " 2>/dev/null || true
}

ensure_mounted() {
  # Mount project
  if ! multipass info "$VM_NAME" | grep -q "$PROJECT_DIR\b"; then
    log "Mounting $PROJECT_DIR → VM:$VM_MOUNT_POINT"
    multipass exec "$VM_NAME" -- sudo mkdir -p "$VM_MOUNT_POINT"
    multipass mount "$PROJECT_DIR" "$VM_NAME":"$VM_MOUNT_POINT"
    success "Mounted project"
  fi

  # Mount ~/.claude so global memory persists on your Mac
  local claude_config="$HOME/.claude"
  mkdir -p "$claude_config"
  if ! multipass info "$VM_NAME" | grep -q "$claude_config\b"; then
    log "Mounting ~/.claude → VM:/home/ubuntu/.claude"
    multipass mount "$claude_config" "$VM_NAME":/home/ubuntu/.claude
    success "Mounted Claude config"
  fi

  # Overlay node_modules with a VM-local copy so Linux-native binaries work
  ensure_node_modules_overlay
}

ensure_node_modules_overlay() {
  local vm_nm_store="/home/ubuntu/.node_modules_overlay${VM_MOUNT_POINT}"

  # Find all node_modules directories at project root and one level deep (monorepo)
  local nm_dirs
  nm_dirs=$(find "$PROJECT_DIR" -maxdepth 3 -name node_modules -type d 2>/dev/null | head -20)
  [ -z "$nm_dirs" ] && return 0

  local needs_install=false
  while IFS= read -r local_nm; do
    local rel_path="${local_nm#"$PROJECT_DIR"}"
    local vm_nm="${vm_nm_store}${rel_path}"
    local vm_target="${VM_MOUNT_POINT}${rel_path}"

    # Create VM-local dir and bind-mount over the mounted node_modules
    if ! multipass exec "$VM_NAME" -- mountpoint -q "$vm_target" 2>/dev/null; then
      log "Overlaying VM-local node_modules for ${rel_path%/node_modules}..."
      multipass exec "$VM_NAME" -- mkdir -p "$vm_nm"
      multipass exec "$VM_NAME" -- sudo mount --bind "$vm_nm" "$vm_target"
      needs_install=true
    fi
  done <<< "$nm_dirs"

  if [ "$needs_install" = true ]; then
    # Find directories containing a package.json that also had node_modules overlaid
    local install_dirs=()
    while IFS= read -r local_nm; do
      local pkg_dir="${local_nm%/node_modules}"
      [ -f "$pkg_dir/package.json" ] && install_dirs+=("$pkg_dir")
    done <<< "$nm_dirs"

    for install_dir in "${install_dirs[@]}"; do
      local rel_install="${install_dir#"$PROJECT_DIR"}"
      local vm_install_dir="${VM_MOUNT_POINT}${rel_install}"
      log "Installing Linux-native dependencies in ${rel_install:-/}..."

      # Detect package manager per directory (walk up to find lock file)
      local pkg_cmd="npm install"
      local search_dir="$install_dir"
      while [ "$search_dir" != "/" ]; do
        if [ -f "$search_dir/pnpm-lock.yaml" ]; then
          multipass exec "$VM_NAME" -- bash -c "export NVM_DIR=\$HOME/.nvm; [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh; command -v pnpm || npm install -g pnpm; pnpm config set store-dir /home/ubuntu/.pnpm-store" 2>/dev/null
          pkg_cmd="pnpm install"
          break
        elif [ -f "$search_dir/yarn.lock" ]; then
          pkg_cmd="yarn install"
          break
        elif [ -f "$search_dir/package-lock.json" ]; then
          break
        fi
        search_dir="$(dirname "$search_dir")"
      done

      multipass exec "$VM_NAME" -- bash -c "
        export NVM_DIR=\$HOME/.nvm
        [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh
        cd '${vm_install_dir}'
        $pkg_cmd
      " && success "Dependencies installed in ${rel_install:-/}" || warn "Dependency install failed in ${rel_install:-/} — run '$pkg_cmd' manually inside the VM"
    done
  fi
}

cleanup_mount() {
  if ! multipass exec "$VM_NAME" -- tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    multipass umount "$VM_NAME":"$VM_MOUNT_POINT" 2>/dev/null || true
  fi
}

SSH_KEY_DIR="$HOME/.claude-vm/ssh"
TUNNEL_PID_FILE="/tmp/claude-vm-tunnel.pid"

ensure_port_forwarding() {
  # Auto-detect ports listening on Mac (localhost and all interfaces)
  local ports
  ports=$(lsof -iTCP -sTCP:LISTEN -n -P 2>/dev/null \
    | awk '/\*:/ || /127\.0\.0\.1:/ {split($9, a, ":"); port=a[2]+0; if (port>=1 && port<=65535) print port}' \
    | sort -un)
  [ -z "$ports" ] && return 0

  local vm_ip
  vm_ip=$(multipass info "$VM_NAME" | grep IPv4 | awk '{print $2}')
  [ -z "$vm_ip" ] && return 0

  # Set up SSH key for tunneling (one-time)
  if [ ! -f "$SSH_KEY_DIR/tunnel_key" ]; then
    mkdir -p "$SSH_KEY_DIR"
    ssh-keygen -t ed25519 -f "$SSH_KEY_DIR/tunnel_key" -N "" -q
    multipass transfer "$SSH_KEY_DIR/tunnel_key.pub" "$VM_NAME":/tmp/claude-vm-tunnel.pub
    multipass exec "$VM_NAME" -- bash -c "
      mkdir -p ~/.ssh && chmod 700 ~/.ssh
      cat /tmp/claude-vm-tunnel.pub >> ~/.ssh/authorized_keys
      chmod 600 ~/.ssh/authorized_keys
      rm /tmp/claude-vm-tunnel.pub
    "
    success "SSH tunnel key installed"
  fi

  # Kill old tunnel if running
  if [ -f "$TUNNEL_PID_FILE" ]; then
    local old_pid
    old_pid=$(cat "$TUNNEL_PID_FILE")
    kill "$old_pid" 2>/dev/null || true
    rm -f "$TUNNEL_PID_FILE"
  fi

  # Build -R flags for each port
  local ssh_args=""
  local port_list=""
  for port in $ports; do
    ssh_args="$ssh_args -R ${port}:127.0.0.1:${port}"
    port_list="${port_list:+$port_list, }$port"
  done

  # Start reverse tunnel in background
  ssh -f -N \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    -o ServerAliveInterval=30 \
    -o ExitOnForwardFailure=no \
    -o LogLevel=ERROR \
    -i "$SSH_KEY_DIR/tunnel_key" \
    $ssh_args \
    ubuntu@"$vm_ip" || { warn "SSH tunnel failed"; return 0; }

  # Find the ssh tunnel PID
  pgrep -f "ssh.*${SSH_KEY_DIR}/tunnel_key.*ubuntu@${vm_ip}" > "$TUNNEL_PID_FILE" 2>/dev/null || true
  success "Port forwarding (Mac → VM): $port_list"
}

vm_ip() {
  multipass exec "$VM_NAME" -- tailscale ip -4 2>/dev/null \
    || multipass info "$VM_NAME" | grep IPv4 | awk '{print $2}'
}

cmd_run() {
  check_prereqs
  # Lock to prevent parallel races during VM setup
  acquire_lock
  ensure_vm
  ensure_bootstrapped
  ensure_host_docker_internal
  sync_hosts
  ensure_mounted
  ensure_port_forwarding
  release_lock

  log "Launching Claude Code in '$PROJECT_NAME'..."
  echo -e "  ${BLUE}Local:${NC}   $WORK_DIR"
  echo -e "  ${BLUE}Root:${NC}    $PROJECT_DIR"
  echo -e "  ${BLUE}Session:${NC} $TMUX_SESSION"
  echo ""

  local inner_cmd
  if [ "$USE_TMUX" = false ]; then
    inner_cmd="
      export NVM_DIR=\$HOME/.nvm
      [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh
      cd '${WORK_DIR}'
      claude --dangerously-skip-permissions
    "
  else
    inner_cmd="
      export NVM_DIR=\$HOME/.nvm
      [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh
      cd '${WORK_DIR}'
      if tmux has-session -t '${TMUX_SESSION}' 2>/dev/null; then
        tmux attach -t '${TMUX_SESSION}'
      else
        tmux new-session -s '${TMUX_SESSION}' \
          \"export NVM_DIR=\$HOME/.nvm; [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh; cd '${WORK_DIR}'; claude --dangerously-skip-permissions; bash\"
      fi
    "
  fi
  multipass exec "$VM_NAME" -- bash -c "$inner_cmd" || true
  cleanup_mount
}

cmd_snapshot() {
  local name="${2:-snap-${PROJECT_NAME}-$(date +%Y%m%d-%H%M)}"
  ensure_vm
  log "Taking snapshot '$name'..."
  multipass snapshot "$VM_NAME" --name "$name"
  success "Snapshot '$name' saved"
}

cmd_restore() {
  local snap="${2:-}"
  [ -n "$snap" ] || { multipass snapshot list "$VM_NAME"; die "Usage: claude-run restore <name>"; }
  warn "Restore '$snap'? This resets all VM state."
  read -rp "Continue? [y/N] " c; [[ "$c" =~ ^[Yy]$ ]] || exit 0
  multipass stop "$VM_NAME" 2>/dev/null || true
  multipass restore "$VM_NAME" --snapshot "$snap"
  multipass start "$VM_NAME"
  success "Restored to '$snap'"
}

cmd_monitor() {
  ensure_vm
  local ip; ip=$(vm_ip)
  open "http://${ip}:${TTYD_PORT}" 2>/dev/null || echo "Open: http://${ip}:${TTYD_PORT}"
}

cmd_status() {
  check_prereqs
  multipass info "$VM_NAME" 2>/dev/null || die "VM not found"
  local ip; ip=$(vm_ip 2>/dev/null || echo "unknown")
  echo ""
  echo -e "  Tailscale IP  : ${GREEN}${ip}${NC}"
  echo -e "  Browser term  : ${BLUE}http://${ip}:${TTYD_PORT}${NC}"
  echo ""
  echo    "  Active sessions:"
  multipass exec "$VM_NAME" -- tmux ls 2>/dev/null || echo "    (none)"
  echo ""
  echo    "  Active mounts:"
  multipass info "$VM_NAME" | grep -A 20 "Mounts" || echo "    (none)"
}

cmd_stop() {
  # Kill SSH tunnel
  if [ -f "$TUNNEL_PID_FILE" ]; then
    kill "$(cat "$TUNNEL_PID_FILE")" 2>/dev/null || true
    rm -f "$TUNNEL_PID_FILE"
  fi
  log "Unmounting all volumes..."
  multipass umount "$VM_NAME" 2>/dev/null || true
  log "Stopping VM..."
  multipass stop "$VM_NAME" --timeout 30 || {
    warn "Graceful stop timed out, forcing..."
    multipass stop "$VM_NAME" --force
  }
  success "VM stopped"
}

usage() {
  echo ""
  echo -e "  ${BLUE}claude-run${NC} — Run Claude Code in an isolated VM"
  echo ""
  echo -e "  ${GREEN}From any project directory:${NC}"
  echo "    claude-run              Launch Claude Code in this repo"
  echo "    claude-run monitor      Open browser terminal (ttyd)"
  echo "    claude-run status       VM info, sessions, mounts"
  echo ""
  echo -e "  ${GREEN}Snapshots:${NC}"
  echo "    claude-run snapshot [name]"
  echo "    claude-run snapshots"
  echo "    claude-run restore <name>"
  echo ""
  echo -e "  ${GREEN}VM:${NC}"
  echo "    claude-run stop"
  echo "    claude-run update"
  echo ""
  echo -e "  ${GREEN}Flags:${NC}"
  echo "    --tmux                  Run inside tmux (session persistence across detach/reattach)"
  echo ""
}

# Parse flags
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --tmux) USE_TMUX=true; shift ;;
    *) die "Unknown flag '$1'. Run: claude-run help" ;;
  esac
done

case "${1:-run}" in
  run|"")    cmd_run ;;
  snapshot)  cmd_snapshot "$@" ;;
  snapshots) multipass snapshot list "$VM_NAME" ;;
  restore)   cmd_restore "$@" ;;
  monitor)   cmd_monitor ;;
  status)    cmd_status ;;
  stop)      cmd_stop ;;
  update)    multipass exec "$VM_NAME" -- bash -c "export NVM_DIR=\$HOME/.nvm; [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh; npm install -g @anthropic-ai/claude-code@latest" ;;
  help|--help|-h) usage ;;
  *) die "Unknown command '$1'. Run: claude-run help" ;;
esac
