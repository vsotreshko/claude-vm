#!/usr/bin/env bash
# claude-run — Run Claude Code in an isolated VM mounted to the current repo
# Install: make install
# Usage:   claude-run [command]

set -euo pipefail

VM_NAME="claude-sandbox"
VM_CPUS="2"
VM_MEMORY="4G"
VM_DISK="30G"
UBUNTU_VERSION="22.04"
BOOTSTRAP_LOCAL="$HOME/.claude-vm/vm-bootstrap.sh"
BOOTSTRAP_URL="https://raw.githubusercontent.com/yourname/claude-vm/main/vm-bootstrap.sh"
TTYD_PORT="7681"

GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
log()     { echo -e "${BLUE}==> ${NC}$1"; }
success() { echo -e "${GREEN} ✓ ${NC}$1"; }
warn()    { echo -e "${YELLOW} ⚠ ${NC}$1"; }
die()     { echo -e "${RED} ✗ ${NC}$1"; exit 1; }

PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-*$//')"
VM_MOUNT_POINT="/workspace/${PROJECT_NAME}"
TMUX_SESSION="claude-${PROJECT_NAME}"

check_prereqs() {
  command -v multipass &>/dev/null || die "Multipass not found. Run: brew install multipass"
}

ensure_vm() {
  if ! multipass info "$VM_NAME" &>/dev/null 2>&1; then
    log "Creating VM '$VM_NAME'..."
    multipass launch --name "$VM_NAME" \
      --cpus "$VM_CPUS" --memory "$VM_MEMORY" --disk "$VM_DISK" "$UBUNTU_VERSION"
    success "VM created"
  fi
  local state
  state=$(multipass info "$VM_NAME" | grep State | awk '{print $2}')
  if [ "$state" != "Running" ]; then
    log "Starting VM..."
    multipass start "$VM_NAME"
    sleep 2
  fi
}

ensure_bootstrapped() {
  if ! multipass exec "$VM_NAME" -- test -f /home/ubuntu/.claude-vm-ready 2>/dev/null; then
    log "Bootstrapping VM (~3 min)..."
    local script
    if [ -f "$BOOTSTRAP_LOCAL" ]; then
      script="$BOOTSTRAP_LOCAL"
    else
      script="/tmp/vm-bootstrap-$$.sh"
      curl -fsSL "$BOOTSTRAP_URL" -o "$script" \
        || die "Bootstrap not found. Put vm-bootstrap.sh at $BOOTSTRAP_LOCAL"
    fi
    multipass transfer "$script" "$VM_NAME":/home/ubuntu/vm-bootstrap.sh
    multipass exec "$VM_NAME" -- chmod +x /home/ubuntu/vm-bootstrap.sh
    multipass exec "$VM_NAME" -- bash /home/ubuntu/vm-bootstrap.sh
    warn "Now authenticate Tailscale:"
    warn "  multipass shell $VM_NAME"
    warn "  sudo tailscale up"
  fi
}

ensure_host_docker_internal() {
  multipass exec "$VM_NAME" -- sudo /usr/local/bin/update-host-docker-internal.sh 2>/dev/null || true
}

ensure_mounted() {
  if multipass info "$VM_NAME" | grep -qF "$PROJECT_DIR"; then return 0; fi
  log "Mounting $PROJECT_DIR → VM:$VM_MOUNT_POINT"
  multipass exec "$VM_NAME" -- sudo mkdir -p "$VM_MOUNT_POINT"
  multipass mount "$PROJECT_DIR" "$VM_NAME":"$VM_MOUNT_POINT"
  success "Mounted"
}

cleanup_mount() {
  if ! multipass exec "$VM_NAME" -- tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    multipass umount "$VM_NAME":"$VM_MOUNT_POINT" 2>/dev/null || true
  fi
}

vm_ip() {
  multipass exec "$VM_NAME" -- tailscale ip -4 2>/dev/null \
    || multipass info "$VM_NAME" | grep IPv4 | awk '{print $2}'
}

cmd_run() {
  check_prereqs
  ensure_vm
  ensure_bootstrapped
  ensure_host_docker_internal
  ensure_mounted

  log "Launching Claude Code in '$PROJECT_NAME'..."
  echo -e "  ${BLUE}Local:${NC}   $PROJECT_DIR"
  echo -e "  ${BLUE}VM:${NC}      $VM_MOUNT_POINT"
  echo -e "  ${BLUE}Session:${NC} $TMUX_SESSION"
  echo ""

  local inner_cmd
  inner_cmd="
    export NVM_DIR=\$HOME/.nvm
    [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh
    cd ${VM_MOUNT_POINT}
    if tmux has-session -t ${TMUX_SESSION} 2>/dev/null; then
      tmux attach -t ${TMUX_SESSION}
    else
      tmux new-session -s ${TMUX_SESSION} \
        \"export NVM_DIR=\$HOME/.nvm; [ -s \$NVM_DIR/nvm.sh ] && . \$NVM_DIR/nvm.sh; cd ${VM_MOUNT_POINT}; claude --dangerously-skip-permissions; bash\"
    fi
  "
  multipass exec --no-map-user-ids "$VM_NAME" -- bash -c "$inner_cmd" || true
  cleanup_mount
}

cmd_snapshot() {
  local name="${2:-snap-${PROJECT_NAME}-$(date +%Y%m%d-%H%M)}"
  ensure_vm
  log "Taking snapshot '$name'..."
  multipass snapshot "$VM_NAME" --name "$name"
  success "Snapshot '$name' saved"
}

cmd_restore() {
  local snap="${2:-}"
  [ -n "$snap" ] || { multipass snapshot list "$VM_NAME"; die "Usage: claude-run restore <name>"; }
  warn "Restore '$snap'? This resets all VM state."
  read -rp "Continue? [y/N] " c; [[ "$c" =~ ^[Yy]$ ]] || exit 0
  multipass stop "$VM_NAME" 2>/dev/null || true
  multipass restore "$VM_NAME" --snapshot "$snap"
  multipass start "$VM_NAME"
  success "Restored to '$snap'"
}

cmd_monitor() {
  ensure_vm
  local ip; ip=$(vm_ip)
  open "http://${ip}:${TTYD_PORT}" 2>/dev/null || echo "Open: http://${ip}:${TTYD_PORT}"
}

cmd_status() {
  check_prereqs
  multipass info "$VM_NAME" 2>/dev/null || die "VM not found"
  local ip; ip=$(vm_ip 2>/dev/null || echo "unknown")
  echo ""
  echo -e "  Tailscale IP  : ${GREEN}${ip}${NC}"
  echo -e "  Browser term  : ${BLUE}http://${ip}:${TTYD_PORT}${NC}"
  echo ""
  echo    "  Active sessions:"
  multipass exec "$VM_NAME" -- tmux ls 2>/dev/null || echo "    (none)"
  echo ""
  echo    "  Active mounts:"
  multipass info "$VM_NAME" | grep -A 20 "Mounts" || echo "    (none)"
}

usage() {
  cat << USAGE

  ${BLUE}claude-run${NC} — Run Claude Code in an isolated VM

  ${GREEN}From any project directory:${NC}
    claude-run              Launch Claude Code in this repo
    claude-run monitor      Open browser terminal (ttyd)
    claude-run status       VM info, sessions, mounts

  ${GREEN}Snapshots:${NC}
    claude-run snapshot [name]
    claude-run snapshots
    claude-run restore <name>

  ${GREEN}VM:${NC}
    claude-run stop
    claude-run update

USAGE
}

case "${1:-run}" in
  run|"")    cmd_run ;;
  snapshot)  cmd_snapshot "$@" ;;
  snapshots) multipass snapshot list "$VM_NAME" ;;
  restore)   cmd_restore "$@" ;;
  monitor)   cmd_monitor ;;
  status)    cmd_status ;;
  stop)      multipass stop "$VM_NAME" ;;
  update)    multipass exec "$VM_NAME" -- bash -c "source ~/.nvm/nvm.sh && npm update -g @anthropic/claude-code" ;;
  help|--help|-h) usage ;;
  *) die "Unknown command '$1'. Run: claude-run help" ;;
esac
